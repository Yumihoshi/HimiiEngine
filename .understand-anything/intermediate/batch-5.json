{
  "nodes": [
    {
      "id": "file:Engine/src/Himii/Renderer/Buffer.cpp",
      "type": "file",
      "name": "Buffer.cpp",
      "filePath": "Engine/src/Himii/Renderer/Buffer.cpp",
      "summary": "实现 VertexBuffer 和 IndexBuffer 的静态工厂方法，根据当前渲染后端 API（目前仅支持 OpenGL）创建对应的平台缓冲区对象。其他后端（Vulkan、DirectX12、Metal）会触发断言报错。",
      "tags": ["工厂方法", "渲染后端", "缓冲区", "api-abstraction"],
      "complexity": "simple"
    },
    {
      "id": "file:Engine/src/Himii/Renderer/Buffer.h",
      "type": "file",
      "name": "Buffer.h",
      "filePath": "Engine/src/Himii/Renderer/Buffer.h",
      "summary": "定义 GPU 缓冲区布局系统的核心数据结构：ShaderDataType 枚举、描述单个顶点属性的 BufferElement 结构体、管理多个属性的 BufferLayout 类，以及 VertexBuffer 和 IndexBuffer 的抽象接口。为几何数据输入管线提供配置基础设施。",
      "tags": ["数据结构", "顶点缓冲布局", "抽象接口", "图形管线", "shader-data-type"],
      "complexity": "complex"
    },
    {
      "id": "file:Engine/src/Himii/Renderer/Renderer.cpp",
      "type": "file",
      "name": "Renderer.cpp",
      "filePath": "Engine/src/Himii/Renderer/Renderer.cpp",
      "summary": "实现渲染管线核心功能：Init 初始化 2D/3D 渲染子系统和渲染命令、Submit 执行着色器绑定、矩阵 Uniform 传参和索引绘制调用。BeginScene/EndScene 管理场景视图投影矩阵状态。",
      "tags": ["渲染管线", "绘制调度", "初始化", "着色器绑定"],
      "complexity": "simple"
    },
    {
      "id": "file:Engine/src/Himii/Renderer/Renderer.h",
      "type": "file",
      "name": "Renderer.h",
      "filePath": "Engine/src/Himii/Renderer/Renderer.h",
      "summary": "声明 Renderer 类，提供渲染管线的静态方法入口（Init、OnWindowResize、BeginScene、EndScene、Submit），包含内部 SceneData 结构体存储视图投影矩阵，以及获取当前渲染 API 的 GetAPI 内联方法。",
      "tags": ["渲染器", "静态门面", "渲染入口", "场景状态"],
      "complexity": "simple"
    },
    {
      "id": "file:Engine/src/Himii/Renderer/Shader.cpp",
      "type": "file",
      "name": "Shader.cpp",
      "filePath": "Engine/src/Himii/Renderer/Shader.cpp",
      "summary": "实现 Shader 的静态工厂方法（依据当前渲染 API 创建 OpenGLShader 实例）和 ShaderLibrary 类的方法：Add 管理着色器注册、Load 创建并缓存着色器、Get/Exists 提供查询功能。ShaderLibrary 充当带名字索引的着色器缓存。",
      "tags": ["着色器工厂", "着色器缓存", "资源管理", "后端抽象"],
      "complexity": "moderate"
    },
    {
      "id": "file:Engine/src/Himii/Renderer/Shader.h",
      "type": "file",
      "name": "Shader.h",
      "filePath": "Engine/src/Himii/Renderer/Shader.h",
      "summary": "定义 Shader 抽象接口（Uniform 参数设置、绑定/解绑等纯虚方法）和 ShaderLibrary 类（基于 unordered_map 的着色器缓存）。Shader 采用纯虚接口模式，支持后端无关的着色器操作。",
      "tags": ["着色器接口", "uniform设置", "纯虚接口", "着色器库"],
      "complexity": "simple"
    },
