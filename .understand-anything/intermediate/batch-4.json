  "nodes": [
    {
      "id": "file:Engine/src/Hepch.h",
      "type": "file",
      "name": "Hepch.h",
      "filePath": "Engine/src/Hepch.h",
      "summary": "预编译头文件（PCH），汇总引擎核心模块的通用头文件，包括标准库、Windows API、Core.h、Log.h 和 Instrumentor.h，并处理 Windows 平台下的 NOMINMAX 与 NEAR/FAR 宏冲突。",
      "tags": ["precompiled-header", "barrel", "core", "platform-abstraction"],
      "complexity": "simple"
    },
    {
      "id": "file:Engine/src/Himii/Core/ConsoleLog.cpp",
      "type": "file",
      "name": "ConsoleLog.cpp",
      "filePath": "Engine/src/Himii/Core/ConsoleLog.cpp",
      "summary": "实现编辑器内控制台日志的静态存储与操作，包括带时间戳的日志条目推送（环形缓冲区）、读取和清空，所有操作均通过互斥锁保证线程安全。",
      "tags": ["logging", "console", "thread-safe", "utility"],
      "complexity": "simple",
      "languageNotes": "使用 std::lock_guard 与 static std::mutex 实现线程安全的日志写入；通过环形缓冲区限制最大条目数（MaxEntries=2000）。"
    },
    {
      "id": "file:Engine/src/Himii/Core/ConsoleLog.h",
      "type": "file",
      "name": "ConsoleLog.h",
      "filePath": "Engine/src/Himii/Core/ConsoleLog.h",
      "summary": "定义控制台日志的数据结构 ConsoleLogEntry 和静态工具类 ConsoleLog，提供编辑器内日志的推送、查询与清空接口，依赖 Log.h 中的 LogLevel 枚举。",
      "tags": ["data-model", "logging", "console", "type-definition"],
      "complexity": "simple"
    },
    {
      "id": "file:Engine/src/Himii/Core/Core.h",
      "type": "file",
      "name": "Core.h",
      "filePath": "Engine/src/Himii/Core/Core.h",
      "summary": "引擎核心基础定义，提供 Scope/Ref 智能指针类型别名、CreateScope/CreateRef 工厂模板函数以及 BIT 和 BIND_EVENT_FN 宏，是整个引擎内存管理的基础。",
      "tags": ["core", "memory-management", "type-definition", "utility"],
      "complexity": "simple",
      "languageNotes": "使用 C++ 可变参数模板与完美转发（std::forward）实现智能指针工厂函数，Scope 映射 std::unique_ptr，Ref 映射 std::shared_ptr。"
    },
    {
      "id": "file:Engine/src/Himii/Core/Log.cpp",
      "type": "file",
      "name": "Log.cpp",
      "filePath": "Engine/src/Himii/Core/Log.cpp",
      "summary": "实现基于 spdlog 的日志系统，支持控制台彩色输出（Debug 模式）和文件输出，提供分级日志打印、格式化输出、断言失败处理（含调试中断与 abort），并同步将日志推送到 ConsoleLog。",
      "tags": ["logging", "spdlog", "assertion", "debugging"],
      "complexity": "moderate",
      "languageNotes": "集成 spdlog 库实现双通道日志（CORE 与 APP）；断言失败时根据平台调用 __debugbreak()（Windows）或 __builtin_trap()（Unix），最终调用 std::abort()。"
    },
    {
      "id": "file:Engine/src/Himii/Core/Log.h",
      "type": "file",
      "name": "Log.h",
      "filePath": "Engine/src/Himii/Core/Log.h",
      "summary": "定义 LogLevel 枚举和静态日志类 Log，声明日志初始化、打印、断言等方法，并提供 HIMII_TRACE/INFO/WARNING/ERROR 系列便捷宏以及可变参数模板方法 PrintFormatted/AssertFormatted。",
      "tags": ["logging", "api-definition", "macro", "spdlog"],
      "complexity": "moderate",
      "languageNotes": "使用 spdlog 作为底层日志库；通过预处理器宏封装日志调用以简化使用；断言宏在 Release 模式下定义为空操作（((void)0)）。"
    },
    {
      "id": "file:Engine/src/Himii/Instrument/Instrumentor.h",
      "type": "file",
      "name": "Instrumentor.h",
      "filePath": "Engine/src/Himii/Instrument/Instrumentor.h",
      "summary": "Header-only 性能分析 instrumentation 库，提供基于 Chrome Tracing JSON 格式的 profiling 功能，包含单例 Instrumentor 管理会话与输出，以及 RAII 风格的 InstrumentationTimer 自动计时代理。",
      "tags": ["profiling", "instrumentation", "performance", "header-only", "debugging"],
      "complexity": "complex",
      "languageNotes": "采用单例模式（Meyers Singleton）管理全局 Instrumentor 实例；InstrumentationTimer 利用 RAII 模式在析构时自动停止计时；输出兼容 Chrome://tracing 的 JSON 事件格式；通过 HIMII_PROFILE 宏控制编译开关。"
    },
